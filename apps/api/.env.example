# PostgreSQL connection string used by Prisma and the API.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/primetrade_ai?schema=public"
NODE_ENV="development"
PORT=5000
API_PREFIX="/api/v1"
CLIENT_URL="http://localhost:5173"
APP_NAME="PrimeTrade API"
ACCESS_TOKEN_SECRET="replace-with-a-long-random-access-secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="replace-with-a-long-random-refresh-secret"
REFRESH_TOKEN_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=12
LOG_LEVEL="info"
JSON_BODY_LIMIT="1mb"
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=200
